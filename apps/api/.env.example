DATABASE_URL_UNPOOLED=""

# JWT — genera valores aleatorios largos (mín. 32 caracteres)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
