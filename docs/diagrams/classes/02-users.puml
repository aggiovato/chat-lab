@startuml users-classes
!theme plain
title Chat Lab — Dominio: Users

skinparam class {
  BackgroundColor #FFF8F0
  BorderColor #CC7700
  HeaderBackgroundColor #FFE8BB
  ArrowColor #885500
}

class UsersModule << (M,#FFD700) Module >> {
}

class UsersController << (C,#4CAF50) Controller >> {
  GET   /api/users/me
  PATCH /api/users/me
  GET   /api/users/search?query=
  GET   /api/users/:id
  --
  + getMe(user: User): Promise<UserResponseDto>
  + updateMe(user: User, dto: UpdateUserDto): Promise<UserResponseDto>
  + search(query: UserSearchQueryDto): Promise<UserResponseDto[]>
  + findById(id: string): Promise<UserResponseDto>
}

class UsersService << (S,#FF9800) Service >> {
  - prisma: PrismaService
  --
  + findById(id: string): Promise<User | null>
  + findByEmail(email: string): Promise<User | null>
  + findByUsername(username: string): Promise<User | null>
  + search(query: string): Promise<User[]>
  + create(data: CreateUserData): Promise<User>
  + update(id: string, data: UpdateUserDto): Promise<User>
  + updateStatus(id: string, status: UserStatus): Promise<void>
}

class UpdateUserDto << (D,#9C27B0) DTO >> {
  + displayName?: string
  + avatarUrl?: string
}

class UserResponseDto << (D,#9C27B0) DTO >> {
  + id: string
  + email: string
  + username: string
  + displayName?: string
  + avatarUrl?: string
  + status: UserStatus
  + createdAt: Date
}

class UserSearchQueryDto << (D,#9C27B0) DTO >> {
  + query: string
}

enum UserStatus << (E,#2196F3) Enum >> {
  ONLINE
  OFFLINE
  AWAY
}

UsersModule     *-- UsersController
UsersModule     *-- UsersService

UsersController --> UsersService      : usa
UsersService    ..> UserStatus        : usa
UsersController ..> UpdateUserDto     : recibe
UsersController ..> UserSearchQueryDto : recibe
UsersController ..> UserResponseDto   : retorna

note right of UsersService
  El modelo User pertenece a este dominio.
  AuthModule solo puede crear/consultar
  usuarios a través de UsersService.
end note

@enduml
